from flask import render_template, request, redirect, url_for, flash, session
  
from utils.db import get_db
  
from utils.decorators import admin_required
  

  
# put these near the top of admin/routes.py
  
SCHOLARSHIPS = ["NONE", "SC", "ST", "BC", "MBC", "OTHER"]
  
QUOTAS = ["REGULAR", "MGMT", "SPORTS", "NCC", "OTHER"]
  

  
FIRST_GRAD_DISCOUNT = 25000  # ₹25,000
  

  

  
def to_int(v, default=0):
  
    try:
  
        return int(v)
  
    except Exception:
  
        return default
  

  

  
def upsert_adjustment(db, student_id: int, category: str, label: str, amount: int):
  
    """
  
    Update if exists else insert. Uniqueness is by (student_id, category, label).
  
    """
  
    row = db.execute(
  
        """
  
        SELECT id
  
        FROM fee_adjustments
  
        WHERE student_id=? AND category=? AND label=?
  
        """,
  
        (student_id, category, label),
  
    ).fetchone()
  

  
    if row:
  
        db.execute(
  
            "UPDATE fee_adjustments SET amount=? WHERE id=?",
  
            (amount, row["id"]),
  
        )
  
    else:
  
        db.execute(
  
            """
  
            INSERT INTO fee_adjustments (student_id, category, label, amount)
  
            VALUES (?, ?, ?, ?)
  
            """,
  
            (student_id, category, label, amount),
  
        )
  

  

  
def delete_adjustment(db, student_id: int, category: str, label: str | None = None):
  
    if label:
  
        db.execute(
  
            "DELETE FROM fee_adjustments WHERE student_id=? AND category=? AND label=?",
  
            (student_id, category, label),
  
        )
  
    else:
  
        db.execute(
  
            "DELETE FROM fee_adjustments WHERE student_id=? AND category=?",
  
            (student_id, category),
  
        )
  

  

  
