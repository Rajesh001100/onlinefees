@admin_bp.route("/audit-logs", methods=["GET"])
@admin_required
def audit_logs():
  
    db = get_db()
  
    inst_id = session["institute_id"]
  

  
    q = (request.args.get("q") or "").strip()
  
    day = (request.args.get("day") or "").strip()  # YYYY-MM-DD
  

  
    where = ["al.institute_id = ?"]
  
    params = [inst_id]
  

  
    if day:
  
        where.append("date(al.created_at) = date(?)")
  
        params.append(day)
  

  
    if q:
  
        like = f"%{q}%"
  
        where.append("""
  
          (
  
            al.action LIKE ?
  
            OR al.entity_type LIKE ?
  
            OR CAST(al.entity_id AS TEXT) LIKE ?
  
            OR IFNULL(u.username,'') LIKE ?
  
            OR IFNULL(s.admission_no,'') LIKE ?
  
            OR IFNULL(s.name,'') LIKE ?
  
            OR IFNULL(al.details,'') LIKE ?
  
          )
  
        """)
  
        params += [like, like, like, like, like, like, like]
  

  
    action = (request.args.get("action") or "").strip()
    if action:
        where.append("al.action = ?")
        params.append(action)

    where_sql = " AND ".join(where)
  

  
    rows = db.execute(
  
        f"""
  
        SELECT
  
          al.id,
  
          al.created_at,
  
          al.action,
  
          al.entity_type,
  
          al.entity_id,
  
          al.details AS details_json,
  
          u.username AS admin_username,
  
          s.admission_no AS student_adm,
  
          s.name AS student_name
  
        FROM audit_logs al
  
        LEFT JOIN users u ON u.id = al.actor_user_id
  
        LEFT JOIN students s ON s.id = al.entity_id AND al.entity_type='student'
  
        WHERE {where_sql}
  
        ORDER BY al.id DESC
  
        LIMIT 300
  
        """,
  
        params
  
    ).fetchall()
  

  
    # distinct actions
    actions_rows = db.execute("SELECT DISTINCT action FROM audit_logs WHERE institute_id=? ORDER BY action", (inst_id,)).fetchall()
    actions = [r["action"] for r in actions_rows]

    return render_template(
        "admin/audit_logs.html",
        logs=rows,
        actions=actions,
        q=q,
        day=day
    )
  

  

  
