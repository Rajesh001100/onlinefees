from io import BytesIO
  
from flask import send_file, flash, redirect, url_for, session
  
from datetime import datetime
  

  
@admin_bp.get("/receipt/<txn_id>.pdf")
  
@admin_required
  
def admin_receipt_pdf(txn_id):
  
    db = get_db()
  
    inst_id = session["institute_id"]
  

  
    # 1) Get payment + student in one go (and validate institute ownership)
  
    row = db.execute(
  
        """
  
        SELECT
  
          p.id            AS payment_id,
  
          p.txn_id,
  
          p.student_id,
  
          p.category,
  
          p.amount,
  
          p.method,
  
          p.status,
  
          p.created_at,
  

  
          s.name,
  
          s.admission_no,
  
          s.register_no,
  
          s.year,
  
          s.class,
  
          s.institute_id,
  
          s.student_email,
  
          s.parent_email
  
        FROM payments p
  
        JOIN students s ON s.id = p.student_id
  
        WHERE p.txn_id = ?
  
          AND s.institute_id = ?
  
        """,
  
        (txn_id, inst_id),
  
    ).fetchone()
  

  
    if not row:
  
        flash("Receipt not found (or unauthorized).", "danger")
  
        return redirect(url_for("admin.dashboard"))
  

  
    if row["status"] != "SUCCESS":
  
        flash("Receipt available only for successful payments.", "warning")
  
        return redirect(url_for("admin.student_view", student_id=row["student_id"]))
  

  
    # 2) Ensure receipt record exists and use stored receipt_no
  
    r = db.execute(
  
        "SELECT receipt_no FROM receipts WHERE payment_id=?",
  
        (row["payment_id"],),
  
    ).fetchone()
  

  
    if not r:
  
        receipt_no = _receipt_no(row["txn_id"])  # stable format you already use
  

  
        try:
  
            db.execute(
  
                "INSERT INTO receipts (receipt_no, payment_id) VALUES (?, ?)",
  
                (receipt_no, row["payment_id"]),
  
            )
  
            db.commit()
  
        except Exception as e:
  
            db.rollback()
  
            # If duplicate happened due to race, re-fetch safely
  
            r2 = db.execute(
  
                "SELECT receipt_no FROM receipts WHERE payment_id=?",
  
                (row["payment_id"],),
  
            ).fetchone()
  
            if not r2:
  
                print("❌ Receipt insert failed:", repr(e))
  
                flash("Receipt generation failed. Check server logs.", "danger")
  
                return redirect(url_for("admin.student_view", student_id=row["student_id"]))
  
            receipt_no = r2["receipt_no"]
  
    else:
  
        receipt_no = r["receipt_no"]
  

  
    # 3) Institute row for PDF header
  
    inst = db.execute(
  
        "SELECT short_name, full_name FROM institutes WHERE id=?",
  
        (row["institute_id"],),
  
    ).fetchone()
  

  
    # 4) Build PDF (your helper expects dict-like rows; sqlite3.Row works fine)
  
    pdf_bytes = _build_receipt_pdf_bytes(row, inst, row, receipt_no)
  

  
    return send_file(
  
        BytesIO(pdf_bytes),
  
        as_attachment=True,
  
        download_name=f"{receipt_no}.pdf",
  
        mimetype="application/pdf",
  
    )
  

  
