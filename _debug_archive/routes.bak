# -----------------------------
  
# Helpers
  
# -----------------------------
  
def rget(row, key, default=None):
  
    """Safe getter for sqlite3.Row (no .get())."""
  
    if row is None:
  
        return default
  
    try:
  
        return row[key] if key in row.keys() else default
  
    except Exception:
  
        return default
  

  

  
def to_int(val, default=0):
  
    try:
  
        if val is None:
  
            return default
  
        s = str(val).strip()
  
        if s == "":
  
            return default
  
        return int(float(s))
  
    except Exception:
  
        return default
  

  

  
def _only_digits(s: str) -> str:
  
    return "".join(ch for ch in (s or "") if ch.isdigit())
  

  

  
def _dob_to_ddmmyyyy(dob_value) -> str:
  
    """
  
    DB dob usually: YYYY-MM-DD
  
    Student password convention: DDMMYYYY
  
    """
  
    if not dob_value:
  
        return ""
  
    s = str(dob_value).strip()
  
    for fmt in ("%Y-%m-%d", "%Y/%m/%d", "%d-%m-%Y", "%d/%m/%Y"):
  
        try:
  
            dt = datetime.strptime(s[:10], fmt)
  
            return dt.strftime("%d%m%Y")
  
        except Exception:
  
            pass
  

  
    digits = _only_digits(s)
  
    if len(digits) == 8 and digits.startswith(("19", "20")):
  
        try:
  
            dt = datetime.strptime(digits, "%Y%m%d")
  
            return dt.strftime("%d%m%Y")
  
        except Exception:
  
            pass
  
    return digits
  

  

  
def upsert_adjustment(db, student_id: int, category: str, label: str, amount: int):
  
    category = (category or "").strip().upper()
  
    label = (label or "").strip()
  
    amount = int(amount or 0)
  

  
    db.execute(
  
        "DELETE FROM fee_adjustments WHERE student_id=? AND category=? AND label=?",
  
        (student_id, category, label),
  
    )
  

  
    if amount != 0:
  
        db.execute(
  
            "INSERT INTO fee_adjustments (student_id, category, label, amount) VALUES (?,?,?,?)",
  
            (student_id, category, label, amount),
  
        )
  

  

  
def sum_adjustment_by_label(db, student_id: int, category: str, label: str) -> int:
  
    row = db.execute(
  
        """
  
        SELECT COALESCE(SUM(amount),0) AS a
  
        FROM fee_adjustments
  
        WHERE student_id=? AND category=? AND label=?
  
        """,
  
        (student_id, category, label),
  
    ).fetchone()
  
    return int(row["a"] or 0)
  

  

  
def _receipt_no(txn_id: str) -> str:
  
    today = datetime.now().strftime("%Y%m%d")
  
    tail = txn_id.replace("TXN-", "").replace("CASH-", "")[-6:]
  
    return f"RCPT-{today}-{tail}"
  

  

  
from io import BytesIO
  
from datetime import datetime
  
from reportlab.pdfgen import canvas
  
from reportlab.lib.pagesizes import A4
  
from reportlab.lib.units import mm
  

  
def _build_receipt_pdf_bytes(student, inst, payment, receipt_no: str) -> bytes:
  
    """
  
    student: sqlite3.Row or dict with student fields
  
    inst: sqlite3.Row or dict with institute fields (optional)
  
    payment: sqlite3.Row or dict with payment fields
  
    """
  

  
    # --- safe getter (works for sqlite3.Row + dict) ---
  
    try:
  
        _rget = rget  # use your existing helper if present
  
    except NameError:
  
        def _rget(obj, key, default=None):
  
            try:
  
                return obj[key]
  
            except Exception:
  
                return default
  

  
    def sget(obj, key, default=""):
  
        v = _rget(obj, key, default)
  
        if v is None:
  
            return default
  
        return str(v)
  

  
    def iget(obj, key, default=0):
  
        try:
  
            return int(_rget(obj, key, default) or 0)
  
        except Exception:
  
            return int(default)
  

  
    def money(n: int) -> str:
  
        try:
  
            return f"₹{int(n):,}"
  
        except Exception:
  
            return f"₹{n}"
  

  
    # Prefer payment time; fallback to now
  
    created_at = _rget(payment, "created_at", None)
  
    receipt_dt_str = None
  
    if created_at:
  
        receipt_dt_str = str(created_at)
  
    else:
  
        receipt_dt_str = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
  

  
    # Nice display date
  
    try:
  
        # If your created_at is ISO-ish, this works; otherwise keep as-is
  
        # We won't force-parse aggressively, just display safely.
  
        display_date = receipt_dt_str
  
    except Exception:
  
        display_date = str(receipt_dt_str)
  

  
    inst_full = sget(inst, "full_name", "") if inst else ""
  
    if not inst_full:
  
        inst_full = sget(student, "institute_id", "-")
  

  
    student_name = sget(student, "name", "-")
  
    admission_no = sget(student, "admission_no", "-")
  
    register_no = sget(student, "register_no", "-") or "-"
  
    class_name = sget(student, "class", "-") or "-"
  
    year_val = _rget(student, "year", None)
  
    year_str = f"{year_val}-Year" if year_val else "-"
  

  
    stud_email = sget(student, "student_email", "-") or "-"
  
    parent_email = sget(student, "parent_email", "-") or "-"
  

  
    txn_id = sget(payment, "txn_id", "-")
  
    method = sget(payment, "method", "-")
  
    status = sget(payment, "status", "-")
  
    category = sget(payment, "category", "-")  # ✅ added
  
    amount = iget(payment, "amount", 0)
  

  
    # --- PDF drawing ---
  
    buf = BytesIO()
  
    c = canvas.Canvas(buf, pagesize=A4)
  
    width, height = A4
  

  
    left = 18 * mm
  
    right = width - 18 * mm
  
    top = height - 18 * mm
  
    line = 6 * mm
  

  
    # Header
  
    c.setFont("Helvetica-Bold", 16)
  
    c.drawString(left, top, "Fee Payment Receipt")
  

  
    c.setFont("Helvetica", 10)
  
    c.drawRightString(right, top, f"Receipt No: {receipt_no}")
  
    c.drawRightString(right, top - line, f"Payment Date: {display_date}")
  

  
    y = top - 2 * line
  
    c.line(left, y, right, y)
  
    y -= 2 * line
  

  
    # Institution
  
    c.setFont("Helvetica-Bold", 12)
  
    c.drawString(left, y, "Institution")
  
    y -= line
  
    c.setFont("Helvetica", 10)
  
    c.drawString(left, y, inst_full)
  
    y -= 2 * line
  

  
    # Student details
  
    c.setFont("Helvetica-Bold", 12)
  
    c.drawString(left, y, "Student Details")
  
    y -= line
  
    c.setFont("Helvetica", 10)
  

  
    details = [
  
        ("Name", student_name),
  
        ("Admission No", admission_no),
  
        ("Register No", register_no),
  
        ("Class", class_name),
  
        ("Year", year_str),
  
        ("Student Email", stud_email),
  
        ("Parent Email", parent_email),
  
    ]
  
    for k, v in details:
  
        c.drawString(left, y, f"{k}: {v}")
  
        y -= line
  

  
    y -= line
  
    c.line(left, y, right, y)
  
    y -= 2 * line
  

  
    # Payment details
  
    c.setFont("Helvetica-Bold", 12)
  
    c.drawString(left, y, "Payment Details")
  
    y -= line
  
    c.setFont("Helvetica", 10)
  

  
    pay_rows = [
  
        ("Transaction ID", txn_id),
  
        ("Category", category),          # ✅ added
  
        ("Method", method),
  
        ("Amount Paid", money(amount)),
  
        ("Status", status),
  
        ("Txn Time", display_date),
  
    ]
  
    for k, v in pay_rows:
  
        c.drawString(left, y, f"{k}: {v}")
  
        y -= line
  

  
    # Footer
  
    y -= 2 * line
  
    c.setFont("Helvetica-Oblique", 9)
  
    c.drawString(left, y, "This is a system-generated receipt. No signature required.")
  

  
    c.showPage()
  
    c.save()
  
    buf.seek(0)
  
    return buf.read()
  

  

  
