from utils.bulk import parse_student_csv

@admin_bp.route("/students/upload", methods=["GET", "POST"])
@admin_required
def upload_students():
    db = get_db()
    inst_id = session["institute_id"]

    if request.method == "POST":
        file = request.files.get("file")
        if not file or not file.filename:
            flash("No file selected.", "danger")
            return redirect(url_for("admin.upload_students"))

        if not file.filename.lower().endswith(".csv"):
             flash("Only CSV files are allowed.", "danger")
             return redirect(url_for("admin.upload_students"))

        # Parse
        students, parse_errors = parse_student_csv(file.stream)

        if parse_errors:
            return render_template("admin/upload_students.html", errors=parse_errors)

        success_count = 0
        insert_errors = []
        hp = _require_hash_password()

        try:
            for s in students:
                admission_no = s["admission_no"].upper()
                exists = db.execute("SELECT 1 FROM students WHERE admission_no=? AND institute_id=?", (admission_no, inst_id)).fetchone()
                if exists:
                    insert_errors.append(f"Skipped {admission_no}: Already exists.")
                    continue

                raw_pwd = _dob_to_ddmmyyyy(s["dob"])
                password_hash = hp(raw_pwd)
                
                db.execute("INSERT INTO users (username, password_hash, role, institute_id, is_active) VALUES (?, ?, 'STUDENT', ?, 1)", (admission_no, password_hash, inst_id))
                user_id = db.execute("SELECT last_insert_rowid() AS id").fetchone()["id"]

                db.execute("""
                    INSERT INTO students (
                        user_id, admission_no, name, dob, year, class, course,
                        student_email, parent_email, student_phone, parent_phone,
                        institute_id, is_active
                    ) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, 1)
                """, (
                    user_id, admission_no, s["name"], s["dob"], s["year"], s["class"], s["course"],
                    s["student_email"], s["parent_email"], s["student_phone"], s["parent_phone"],
                    inst_id
                ))
                
                # Create fee adjustments for hostel if needed? 
                # Bulk upload usually just creates the student. Adjustments are manual or separate.
                # But creating student triggers audits?
                # Let's add audit log
                audit_log(db, action="STUDENT_IMPORTED", entity_type="student", entity_id=user_id, details={"adm": admission_no})

                success_count += 1
            
            db.commit()
            if success_count > 0:
                flash(f"Successfully uploaded {success_count} students.", "success")
            
            if insert_errors:
                return render_template("admin/upload_students.html", errors=insert_errors, success_count=success_count)
                
            return redirect(url_for("admin.dashboard"))
            
        except Exception as e:
            db.rollback()
            print("Bulk upload failed:", e)
            flash(f"Critical error: {str(e)}", "danger")
            return redirect(url_for("admin.upload_students"))

    return render_template("admin/upload_students.html")


# -----------------------------
# Reports & Notifications (Phase 6)
# -----------------------------
from utils.reports import generate_daily_collection_pdf, generate_dues_csv
from utils.notifications import send_alert
from flask import send_file, Response, make_response
from datetime import date

@admin_bp.route("/reports", methods=["GET"])
@admin_required
def reports():
    return render_template("admin/reports.html", today=date.today())

@admin_bp.route("/reports/daily-pdf", methods=["GET"])
@admin_required
def download_daily_report():
    db = get_db()
    inst_id = session["institute_id"]
    date_str = request.args.get("date") or str(date.today())

    pdf_bytes = generate_daily_collection_pdf(db, inst_id, date_str)
    
    response = make_response(pdf_bytes)
    response.headers['Content-Type'] = 'application/pdf'
    response.headers['Content-Disposition'] = f'inline; filename=DailyCollection_{date_str}.pdf'
    return response

@admin_bp.route("/reports/dues-csv", methods=["GET"])
@admin_required
def download_dues_report():
    db = get_db()
    inst_id = session["institute_id"]
    
    # This might be slow for many students, optimization via SQL needed for real world
    csv_str = generate_dues_csv(db, inst_id)
    
    return Response(
        csv_str,
        mimetype="text/csv",
        headers={"Content-disposition": "attachment; filename=Outstanding_Dues.csv"}
    )

@admin_bp.route("/reports/send-notifications", methods=["POST"])
@admin_required
def send_notifications():
    db = get_db()
    inst_id = session["institute_id"]
    
    # Get all active students
    students = db.execute("SELECT id, admission_no, student_phone FROM students WHERE institute_id=? AND is_active=1", (inst_id,)).fetchall()
    
    from utils.fees import get_fee_state_for_student
    count = 0
    
    for s in students:
        state = get_fee_state_for_student(db, s["id"])
        due = state.get("due_total", 0)
        if due > 0:
            msg = f"Dear Student, you have outstanding fees of Rs. {due}. Please pay immediately to avoid late fees."
            send_alert(s["id"], msg, type="SMS")
            count += 1
            
    flash(f"Alerts sent to {count} students with outstanding dues.", "success")
    return redirect(url_for("admin.reports"))

