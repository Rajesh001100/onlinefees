from flask import render_template, request, redirect, url_for, flash, session
  
from utils.db import get_db
  
from utils.decorators import admin_required
  

  
# If you already have these helpers elsewhere, remove duplicates.
  
def to_int(v, default=0):
  
    try:
  
        return int(v)
  
    except Exception:
  
        return default
  

  
def _only_digits(s: str) -> str:
  
    return "".join(ch for ch in (s or "") if ch.isdigit())
  

  
def _dob_to_ddmmyyyy(dob_value) -> str:
  
    # expects YYYY-MM-DD from <input type="date">
  
    s = (dob_value or "").strip()
  
    if len(s) >= 10 and s[4] == "-" and s[7] == "-":
  
        yyyy, mm, dd = s[:4], s[5:7], s[8:10]
  
        return f"{dd}{mm}{yyyy}"
  
    digits = _only_digits(s)
  
    if len(digits) == 8 and digits.startswith(("19", "20")):
  
        yyyy, mm, dd = digits[:4], digits[4:6], digits[6:8]
  
        return f"{dd}{mm}{yyyy}"
  
    return digits
  

  
def _require_hash_password():
  
    # adjust to your project’s hashing helper
  
    from werkzeug.security import generate_password_hash
  
    return generate_password_hash
  

  
# Keep these consistent with your UI dropdowns
  
SCHOLARSHIPS = ["NONE", "GOVT", "SPORTS", "MERIT", "OTHER"]
  
QUOTAS = ["REGULAR", "MGMT", "NRI", "SPORTS", "OTHER"]
  

  
def _fee_plan_exists(db, institute_id, course, year):
  
    row = db.execute(
  
        """
  
        SELECT 1
  
        FROM fee_plans
  
        WHERE institute_id=? AND course=? AND year=?
  
        LIMIT 1
  
        """,
  
        (institute_id, course, year),
  
    ).fetchone()
  
    return bool(row)
  

  
def _insert_adjustment(db, student_id: int, category: str, label: str, amount: int):
  
    # only store non-zero
  
    if int(amount or 0) == 0:
  
        return
  
    db.execute(
  
        """
  
        INSERT INTO fee_adjustments (student_id, category, label, amount)
  
        VALUES (?, ?, ?, ?)
  
        """,
  
        (student_id, category, label, int(amount)),
  
    )
  

  
