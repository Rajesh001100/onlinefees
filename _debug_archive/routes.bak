# -----------------------------
  
# Cash Counter Payment
  
# -----------------------------
  
from datetime import datetime
  
import uuid
  
from io import BytesIO
  
from flask import flash, redirect, url_for, session, request
  
from utils.mailer import send_receipt_email  # must exist
  
# make sure _receipt_no and _build_receipt_pdf_bytes exist in scope
  

  
@admin_bp.post("/student/<int:student_id>/cash-pay")
  
@admin_required
  
def admin_cash_pay(student_id):
  
    db = get_db()
  
    inst_id = session["institute_id"]
  

  
    # Pull full student (need emails + details for receipt)
  
    s = db.execute(
  
        """
  
        SELECT id, institute_id, name, admission_no, register_no, year, class,
  
               student_email, parent_email
  
        FROM students
  
        WHERE id=? AND institute_id=?
  
        """,
  
        (student_id, inst_id),
  
    ).fetchone()
  

  
    if not s:
  
        flash("Student not found.", "danger")
  
        return redirect(url_for("admin.dashboard"))
  

  
    category = (request.form.get("category") or "").strip().upper()
  
    amount = to_int(request.form.get("cash_amount"), 0)
  

  
    if amount <= 0:
  
        flash("Amount must be greater than 0.", "danger")
  
        return redirect(url_for("admin.student_view", student_id=student_id))
  

  
    fee_state = get_fee_state_for_student(db, student_id=student_id)
  
    if not fee_state or not fee_state.get("ok"):
  
        flash("Fee state error. Check fee plan/course mapping.", "danger")
  
        return redirect(url_for("admin.student_view", student_id=student_id))
  

  
    category_due = fee_state.get("due", {})  # ✅ your fees engine returns 'due' dict
  
    if not isinstance(category_due, dict) or category not in category_due:
  
        flash("Invalid fee category.", "danger")
  
        return redirect(url_for("admin.student_view", student_id=student_id))
  

  
    due = int(category_due.get(category, 0) or 0)
  
    if due <= 0:
  
        flash(f"No due for {category}.", "warning")
  
        return redirect(url_for("admin.student_view", student_id=student_id))
  

  
    if amount > due:
  
        flash(f"Amount exceeds due for {category} (₹{due:,}).", "danger")
  
        return redirect(url_for("admin.student_view", student_id=student_id))
  

  
    txn_id = f"CASH-{datetime.now().strftime('%Y%m%d')}-{uuid.uuid4().hex[:6].upper()}"
  

  
    try:
  
        db.execute(
  
            """
  
            INSERT INTO payments (student_id, txn_id, category, amount, method, status)
  
            VALUES (?, ?, ?, ?, 'CASH_COUNTER', 'SUCCESS')
  
            """,
  
            (student_id, txn_id, category, amount),
  
        )
  
        db.commit()
  
    except Exception as e:
  
        db.rollback()
  
        print("❌ Cash payment insert failed:", repr(e))
  
        flash("Failed to record cash payment. Check server logs.", "danger")
  
        return redirect(url_for("admin.student_view", student_id=student_id))
  

  
    # --- Build receipt + send email (do NOT rollback payment if email fails) ---
  
    inst = db.execute(
  
        "SELECT short_name, full_name FROM institutes WHERE id=?",
  
        (inst_id,),
  
    ).fetchone()
  

  
    receipt_no = _receipt_no(txn_id)
  

  
    payment_obj = {
  
        "txn_id": txn_id,
  
        "category": category,
  
        "amount": amount,
  
        "method": "CASH_COUNTER",
  
        "status": "SUCCESS",
  
        "created_at": datetime.now().strftime("%Y-%m-%d %H:%M:%S"),
  
    }
  

  
    pdf_bytes = _build_receipt_pdf_bytes(s, inst, payment_obj, receipt_no)
  

  
    subject = f"Fee Receipt - {receipt_no}"
  
    body = (
  
        f"Hello {s['name']},\n\n"
  
        f"Your cash payment was recorded successfully.\n\n"
  
        f"Receipt No: {receipt_no}\n"
  
        f"Transaction ID: {txn_id}\n"
  
        f"Category: {category}\n"
  
        f"Amount Paid: ₹{amount:,}\n"
  
        f"Method: CASH_COUNTER\n\n"
  
        f"Regards,\n{inst['full_name'] if inst else 'Institution'}\n"
  
    )
  

  
    recipients = []
  
    if (s["student_email"] or "").strip():
  
        recipients.append(s["student_email"].strip())
  
    if (s["parent_email"] or "").strip():
  
        recipients.append(s["parent_email"].strip())
  

  
    sent = 0
  
    for to_email in recipients:
  
        try:
  
            send_receipt_email(to_email, subject, body, pdf_bytes, f"{receipt_no}.pdf")
  
            sent += 1
  
        except Exception as e:
  
            print("❌ Cash receipt email failed:", to_email, "|", repr(e))
  

  
    if recipients and sent == 0:
  
        flash(f"Cash payment recorded for {category} (₹{amount:,}). Email failed.", "warning")
  
    elif recipients and sent > 0:
  
        flash(f"Cash payment recorded for {category} (₹{amount:,}). Receipt emailed.", "success")
  
    else:
  
        flash(f"Cash payment recorded for {category} (₹{amount:,}). No email on file.", "success")
  

  
    return redirect(url_for("admin.student_view", student_id=student_id))
  
