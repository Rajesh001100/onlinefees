# -----------------------------
# Dashboard
# -----------------------------
  
@admin_bp.get("/dashboard")
  
@admin_required
  
def dashboard():
  
    db = get_db()
  

  
    role = session.get("role")
  

  
    # founder can filter: /admin/dashboard?inst=ENG
  
    selected_inst = (request.args.get("inst") or "").strip() if role == "FOUNDER" else None
  

  
    if role == "ADMIN":
  
        inst_id = session.get("institute_id")
  

  
        inst = db.execute(
  
            "SELECT id, short_name, full_name FROM institutes WHERE id=?",
  
            (inst_id,),
  
        ).fetchone()
  

  
        rows = db.execute(
  
            """
  
            SELECT year, COUNT(*) AS c
  
            FROM students
  
            WHERE institute_id=? AND COALESCE(is_active,1)=1
  
            GROUP BY year
  
            ORDER BY year
  
            """,
  
            (inst_id,),
  
        ).fetchall()
  

  
        counts = {r["year"]: r["c"] for r in rows}
  
        year_cards = [{"year": y, "count": counts.get(y, 0)} for y in [1, 2, 3, 4]]
  

  
        return render_template(
  
            "admin/dashboard.html",
  
            inst=inst,
  
            year_cards=year_cards,
  
        )
  

  
    # ---------- FOUNDER MODE ----------
  
    institutes = db.execute(
  
        "SELECT id, short_name, full_name FROM institutes ORDER BY id"
  
    ).fetchall()
  

  
    where = ["COALESCE(is_active,1)=1"]
  
    params = []
  

  
    if selected_inst:
  
        where.append("institute_id=?")
  
        params.append(selected_inst)
  

  
    where_sql = " AND ".join(where)
  

  
    # totals across scope grouped by year
  
    rows = db.execute(
  
        f"""
  
        SELECT year, COUNT(*) AS c
  
        FROM students
  
        WHERE {where_sql}
  
        GROUP BY year
  
        ORDER BY year
  
        """,
  
        params,
  
    ).fetchall()
  

  
    counts = {r["year"]: r["c"] for r in rows}
  
    year_cards = [{"year": y, "count": counts.get(y, 0)} for y in [1, 2, 3, 4]]
  

  
    # inst is None for founder (or you can set label)
  
    return render_template(
  
        "admin/dashboard.html",
  
        inst=None,
  
        year_cards=year_cards,
  
        institutes=institutes,
  
        selected_inst=selected_inst,
  
        is_founder=True,
  
    )
  

  

  
