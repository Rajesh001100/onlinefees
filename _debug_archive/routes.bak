@admin_bp.post("/student/<int:student_id>/reset-payments")
  
@admin_required
  
def reset_payments(student_id):
  
    db = get_db()
  
    inst_id = session["institute_id"]
  

  
    ok = db.execute(
  
        "SELECT id FROM students WHERE id=? AND institute_id=?",
  
        (student_id, inst_id),
  
    ).fetchone()
  

  
    if not ok:
  
        flash("Student not found.", "danger")
  
        return redirect(url_for("admin.dashboard"))
  

  
    try:
  
        db.execute(
  
            "DELETE FROM receipts WHERE payment_id IN (SELECT id FROM payments WHERE student_id=?)",
  
            (student_id,),
  
        )
  
    except Exception:
  
        pass
  

  
    db.execute("DELETE FROM payments WHERE student_id=?", (student_id,))
  
    db.commit()
  

  
    flash("All payments cleared (demo reset).", "success")
  
    return redirect(url_for("admin.student_view", student_id=student_id))
  

  

  
