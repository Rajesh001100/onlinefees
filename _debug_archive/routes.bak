def _is_75(quota_type: str) -> bool:
  
    qt = (quota_type or "").strip().upper()
  
    return qt in {"7.5 RESERVATION", "7.5", "7.5%", "7_5", "RES7_5", "RESERVATION7_5", "75RES"}
  

  

  

  
